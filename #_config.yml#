# Permalinks
#
# Use of `relative_permalinks` ensures post links from the index work properly.
permalink:           pretty
relative_permalinks: true

# Setup
title:               GNewArchaeology
tagline:             Free/Libre Software and Reproducible Research in Archaeology
url:                 http://gnewarchaeology.it
paginate:            1
baseurl:             ""

# Assets
#
# We specify the directory for Jekyll so we can use @imports.
sass:
  sass_dir:          _sass
  style:            :compressed

# About/contact
author:
  name:              Domenico Giusti
###  url:               https://twitter.com/
  email:             dncgst@gnewarchaeology.it

# Custom vars
version:             2.0.0
github:
  repo:              https://github.com/dncgst/dncgst.github.io

# Defaults
defaults:
  -
scope:
	path: "" # an empty string here means all files in the project 
	type: "posts" # previously `post` in Jekyll 2.2.
values:
	layout: "default"